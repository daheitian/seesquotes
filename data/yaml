name: Sync Notion Data

on:
  schedule:
    - cron: '*/10 * * * *'  # 每 10 分钟同步一次
  workflow_dispatch:         # 支持手动触发
  push:
    branches: [main]         # 推送代码时也触发（可选）

jobs:
  sync:
    runs-on: ubuntu-latest
    
    steps:
      - uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
      
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      
      - name: Install dependencies
        run: npm install @notionhq/client
      
      - name: Sync from Notion
        env:
          NOTION_TOKEN: ${{ secrets.NOTION_TOKEN }}
          NOTION_DATABASE_ID: ${{ secrets.NOTION_DATABASE_ID }}
        run: |
          cat > sync.js << 'EOF'
          const { Client } = require('@notionhq/client');
          const fs = require('fs');
          
          const notion = new Client({ auth: process.env.NOTION_TOKEN });
          const databaseId = process.env.NOTION_DATABASE_ID;
          
          async function sync() {
            try {
              console.log('🔄 开始同步 Notion 数据...');
              
              // 查询数据库
              const response = await notion.databases.query({
                database_id: databaseId,
                sorts: [{ timestamp: 'created_time', direction: 'descending' }],
                page_size: 100
              });
              
              console.log(`📊 获取到 ${response.results.length} 条记录`);
              
              // 解析数据
              const posts = response.results.map(page => {
                const props = page.properties;
                
                // 提取标题（支持多种字段名）
                const title = 
                  props.Name?.title?.[0]?.plain_text ||
                  props.Title?.title?.[0]?.plain_text ||
                  props.标题?.title?.[0]?.plain_text ||
                  '无标题';
                
                // 提取内容
                const content = 
                  props.Content?.rich_text?.[0]?.plain_text ||
                  props.内容?.rich_text?.[0]?.plain_text ||
                  props.Note?.rich_text?.[0]?.plain_text ||
                  '';
                
                // 提取标签（如果有）
                const tags = (props.Tags?.multi_select || props.标签?.multi_select || [])
                  .map(t => t.name);
                
                return {
                  id: page.id,
                  title: title,
                  content: content,
                  tags: tags,
                  date: page.created_time,
                  lastEdited: page.last_edited_time,
                  url: page.url
                };
              });
              
              // 写入文件（带时间戳）
              const output = {
                lastSync: new Date().toISOString(),
                count: posts.length,
                posts: posts
              };
              
              fs.writeFileSync('notion-data.json', JSON.stringify(output, null, 2));
              console.log('✅ 同步完成:', new Date().toLocaleString('zh-CN'));
              
            } catch (error) {
              console.error('❌ 同步失败:', error.message);
              process.exit(1);
            }
          }
          
          sync();
          EOF
          
          node sync.js
      
      - name: Commit and push
        run: |
          git config --local user.email 'action@github.com'
          git config --local user.name 'GitHub Action'
          
          # 检查文件是否有变化
          if git diff --quiet && git diff --staged --quiet; then
            echo "📭 无变化，跳过提交"
            exit 0
          fi
          
          git add notion-data.json
          git commit -m "sync: update from Notion [$(date +'%Y-%m-%d %H:%M:%S')]"
          git push
      
      - name: Trigger Pages rebuild
        if: success()
        run: |
          # 可选：强制刷新 GitHub Pages 缓存
          echo "🚀 数据已更新，Pages 将在 1-2 分钟后刷新"
